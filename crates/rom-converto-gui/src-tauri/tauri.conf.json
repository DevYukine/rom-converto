{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.0.0/crates/tauri-cli/config.schema.json",
	"productName": "rom-converto",
	"identifier": "com.devyukine.rom-converto",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:3001",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../.output/public"
	},
	"bundle": {
		"createUpdaterArtifacts": false,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"app": {
		"windows": [
			{
				"title": "rom-converto",
				"width": 1200,
				"height": 720,
				"minWidth": 960,
				"minHeight": 600,
				"center": true,
				"backgroundColor": "#18181b",
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"shell": {
			"open": true
		},
		"updater": {
			"endpoints": [
				"https://github.com/DevYukine/rom-converto/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyMjRFOUQ5QTM2Qzk4MjcKUldRbm1HeWoyZWtrSWlmRU00MXp3M3p1NVZORk1XUjIwaUtTa0IxcmtWUElHK2NTckNoRHRNYkEK",
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
